# 실서비스 전환 시: https://developers.tosspayments.com/ 에서 라이브 키 발급
VITE_TOSS_CLIENT_KEY=test_ck_D5GePWvyJnrK0W0k6q8gLzN97Eoq
TOSS_SECRET_KEY=test_sk_zXLkKEypNArWmo50nX3lmeaxYG5R

# 라이브 키 예시 (실서비스용 - 토스페이먼츠 가입 후 발급)
# VITE_TOSS_CLIENT_KEY=live_ck_XXXXXXXXXXXXXXXXXXXXXX
# TOSS_SECRET_KEY=live_sk_XXXXXXXXXXXXXXXXXXXXXX

